# =========================================================================
# RedeeMERP Environment Configuration Template
# Duplicate this file to '.env' and fill in your actual credentials.
# =========================================================================

# Google Maps API Key (Needed for maps rendering and directions)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Gemini AI API Key (Needed for voice destination parsing; app falls back offline without it)
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Web-only: set to "true" to use RCCG Camp mock location during local testing.
EXPO_PUBLIC_USE_MOCK_LOCATION=false
