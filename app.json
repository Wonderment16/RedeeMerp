{
  "expo": {
    "name": "RedeeMERP",
    "slug": "redeemap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.redeemerp.navigation",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "RedeeMERP tracks your location in the background to provide voice navigation around RCCG Camp while your phone is in your pocket.",
        "NSLocationWhenInUseUsageDescription": "RedeeMERP tracks your location to guide you around RCCG Camp.",
        "NSMicrophoneUsageDescription": "RedeeMERP uses the microphone to listen to your voice navigation commands.",
        "NSSpeechRecognitionUsageDescription": "RedeeMERP uses speech recognition to parse and understand your navigation destinations.",
        "UIBackgroundModes": [
          "location",
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.redeemerp.navigation",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "locationAlwaysAndWhenInUsePermission": "RedeeMERP tracks your location in the background to provide voice navigation around RCCG Camp while your phone is in your pocket."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "enableBackgroundPlayback": true
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "RedeeMERP uses the microphone to listen to your voice navigation commands.",
          "speechRecognitionPermission": "RedeeMERP uses speech recognition to parse and understand your navigation destinations.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b1ceec7a-fde7-4d97-a32c-e7b087db4116"
      }
    },
    "owner": "victor-nkemuka",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b1ceec7a-fde7-4d97-a32c-e7b087db4116"
    }
  }
}
